# Normalize line endings. Check in LF, check out native.
# Kills the "LF will be replaced by CRLF" warnings on Windows.
* text=auto eol=lf

# Explicitly text so they never get treated as binary.
*.js        text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.sh        text eol=lf
*.xml       text eol=lf
*.svg       text eol=lf

# Binary assets.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.woff      binary
*.woff2     binary
